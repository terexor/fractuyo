{
	"source": {
		"include": [
			"src"
		],
		"includePattern": ".+\\.js(doc|x)?$",
		"exclude": [
			"node_modules"
		]
	},
	"opts": {
		"template": "node_modules/docdash",
		"destination": "./docs",
		"recurse": true
	},
	"docdash": {
		"search": true,
		"collapse": true,
		"typedefs": true,
		"removeTrailingSlash": true
	}
}