{
	"name": "fractuyo",
	"version": "0.5.6",
	"description": "Generates electronic invoices and other tax documents compliant with Sunat (Peru) standards.",
	"main": "dist/fractuyo.min.js",
	"type": "module",
	"types": "./types/fractuyo.d.ts",
	"files": [
		"types",
		"dist"
	],
	"exports": {
		".": {
			"types": "./types/fractuyo.d.ts",
			"import": "./dist/fractuyo.min.js",
			"default": "./dist/fractuyo.min.js"
		}
	},
	"scripts": {
		"build:types": "tsc",
		"build:dist": "esbuild src/fractuyo.js --bundle --minify --format=esm --outfile=dist/fractuyo.min.js --external:@xmldom/xmldom --external:jszip --external:written-number --external:xmldsigjs --external:xmllint-wasm --external:asn1js",
		"prepublishOnly": "npm run build:types && npm run build:dist",
		"test": "ava --serial",
		"test:benchmark": "ava ./tests/invoice.benchmark.test.js",
		"test:invoice": "ava ./tests/invoice.test.js",
		"test:invoice:boleta": "ava ./tests/invoice.boleta.test.js",
		"test:invoice:detraction": "ava ./tests/invoice.detraction.test.js",
		"test:despatch": "ava ./tests/despatch.*",
		"test:credit": "ava ./tests/credit.*",
		"test:debit": "ava ./tests/debit.*"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/terexor/fractuyo.git"
	},
	"keywords": [
		"invoice",
		"invoice generator",
		"e-invoice",
		"electronic invoice",
		"billing",
		"factura electrónica",
		"boleta",
		"boleta de venta",
		"firma electrónica",
		"Peru",
		"Peruvian tax",
		"UBL 2.1",
		"XML invoice",
		"XML signature",
		"digital signature",
		"receipt",
		"credit note",
		"debit note",
		"despatch",
		"taxpayer",
		"CPE",
		"Sunat"
	],
	"author": "Terexor",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/terexor/fractuyo/issues"
	},
	"homepage": "https://github.com/terexor/fractuyo#readme",
	"dependencies": {
		"@xmldom/xmldom": "^0.9.5",
		"asn1js": "^3.0.5",
		"jszip": "^3.10.1",
		"written-number": "^0.11.1",
		"xmldsigjs": "2.6.1",
		"xml-core": "1.1.5",
		"xmllint-wasm": "^4.0.2"
	},
	"devDependencies": {
		"@types/node": "^22.15.01",
		"ava": "^6.1.3",
		"esbuild": "^0.27.4",
		"jsdom": "^25.0.0",
		"typescript": "^6.0.2"
	}
}
